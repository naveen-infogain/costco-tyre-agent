ANTHROPIC_API_KEY=sk-ant-...
APP_ENV=dev
APP_PORT=8080

# Arize observability (optional — tracing disabled if not set)
# Get these from app.arize.com → your Space → Settings → API Keys
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=costco-tyre-agent
# Twilio WhatsApp — booking confirmation message
# Get from console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox sender (use whatsapp:+14155238886 for Twilio sandbox)
# or your approved WhatsApp Business number: whatsapp:+1XXXXXXXXXX
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
# The recipient number for demo (your own WhatsApp number in E.164 format)
TWILIO_TO_WHATSAPP=whatsapp:+91XXXXXXXXXX

SESSION_TTL_MINUTES=30
CART_RESERVE_MINUTES=15
DROP_IDLE_THRESHOLD_SECONDS=120
LOG_LEVEL=INFO

# ElevenLabs Voice Agent
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Default voice: Rachel (professional, warm, clear)
# Other good options: Adam (21m00Tcm4TlvDq8ikWAM), Bella (EXAVITQu4vr4xnSDxMaL)
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# eleven_turbo_v2_5 = lowest latency (recommended for real-time chat)
# eleven_multilingual_v2 = highest quality
